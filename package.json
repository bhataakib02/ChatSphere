{
  "name": "chatsphere",
  "private": true,
  "description": "Run scripts from repo root (frontend lives in ./frontend)",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "docker:db": "docker compose up -d postgres",
    "docker:stack": "docker compose --profile stack up --build -d"
  }
}
