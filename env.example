# Example environment variables (set in your shell, IDE run config, or Docker).
# Copy and adjust; never commit a file with real secrets.

SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:postgresql://localhost:5432/chatsphere
DB_USER=postgres
DB_PASSWORD=postgres

# Base64-encoded secret for JWT HS256 (decode length must be >= 256 bits).
JWT_SECRET=

# Optional: comma-separated CORS origin patterns for the browser client
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173

# Production profile requires DB_URL, DB_USER, DB_PASSWORD, JWT_SECRET (no defaults in application-prod.yml).

# --- Frontend (Vite) — required when UI and API are on different hosts (e.g. Vercel + Railway)
# VITE_API_BASE_URL=https://your-backend.example.com/api
# VITE_WS_URL=wss://your-backend.example.com/ws
#
# Set the same names in Vercel → Project → Settings → Environment Variables, then redeploy.
# Local dev on localhost:5173 usually omits these (Vite proxy uses /api and /ws).

# --- Docker full stack: docker compose --profile stack up --build
# SPRING_PROFILES_ACTIVE=dev
# JWT_SECRET=   # optional in dev (default in application-dev.yml); required for prod
# SPRING_JPA_HIBERNATE_DDL_AUTO=update   # if using prod profile on an empty database
# CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
# FRONTEND_PORT=3000
# BACKEND_PORT=8080
